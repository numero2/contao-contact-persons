<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.1">
<file>
<body>
    <!-- ACTIONS -->
    <trans-unit id="tl_contact_person.import.0">
        <source>Import</source>
        <target>Importieren</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.import.1">
        <source>Import multiple contact persons at once</source>
        <target>Mehrere Ansprechpartner auf einmal importieren</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.edit">
        <source>Edit contact person ID %s</source>
        <target>Ansprechpartner ID %s bearbeiten</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.delete">
        <source>Delete contact person ID %s</source>
        <target>Ansprechpartner ID %s löschen</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.toggle">
        <source>Publish/unpublish contact person ID %s</source>
        <target>Ansprechpartner ID %s veröffentlichen/unveröffentlichen</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.show">
        <source>Show details of contact person ID %s</source>
        <target>Details des Ansprechpartner ID %s anzeigen</target>
    </trans-unit>
    <!-- LEGENDS -->
    <trans-unit id="tl_contact_person.common_legend">
        <source>General</source>
        <target>Allgemein</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.vcf_legend">
        <source>VCF File</source>
        <target>VCF Datei</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.source_legend">
        <source>Image</source>
        <target>Bild</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.page_legend">
        <source>Pages</source>
        <target>Seiten</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.publish_legend">
        <source>Publication</source>
        <target>Veröffentlichung</target>
    </trans-unit>
    <!-- FIELDS -->
    <trans-unit id="tl_contact_person.title.0">
        <source>Title</source>
        <target>Titel</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.title.1">
        <source>Please enter the title.</source>
        <target>Bitte geben Sie den Titel ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.salutation.0">
        <source>Salutation</source>
        <target>Anrede</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.salutation.1">
        <source>Please enter the salutation.</source>
        <target>Bitte geben Sie die Anrede ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.firstname.0">
        <source>First name</source>
        <target>Vorname</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.firstname.1">
        <source>Please enter the first name.</source>
        <target>Bitte geben Sie den Vornamen ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.lastname.0">
        <source>Last name</source>
        <target>Nachname</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.lastname.1">
        <source>Please enter the last name.</source>
        <target>Bitte geben Sie den Nachnamen ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.position.0">
        <source>Position</source>
        <target>Position</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.position.1">
        <source>Please enter the position.</source>
        <target>Bitte geben Sie die Position ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.phone.0">
        <source>Phone number</source>
        <target>Telefonnummer</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.phone.1">
        <source>Please enter the phone number.</source>
        <target>Bitte geben Sie die Telefonnummer ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.fax.0">
        <source>Fax number</source>
        <target>Faxnummer</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.fax.1">
        <source>Please enter the fax number.</source>
        <target>Bitte geben Sie die Faxnummer ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.email.0">
        <source>Email address</source>
        <target>E-Mail-Adresse</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.email.1">
        <source>Please enter a valid email address.</source>
        <target>Bitte geben Sie eine gültige E-Mail-Adresse ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.street.0">
        <source>Street</source>
        <target>Straße</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.street.1">
        <source>Please enter the street.</source>
        <target>Bitte geben Sie den Straße ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.postal.0">
        <source>Postal code</source>
        <target>Postleitzahl</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.postal.1">
        <source>Please enter the postal code.</source>
        <target>Bitte geben Sie die Postleitzahl ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.city.0">
        <source>City</source>
        <target>Ort</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.city.1">
        <source>Please enter the city.</source>
        <target>Bitte geben Sie den Ort ein.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.generate_vcf.0">
        <source>Generate VCF file</source>
        <target>VCF Datei ausgeben</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.generate_vcf.1">
        <source>Should a VCF file be generated?</source>
        <target>Soll eine VCF Datei ausgegeben werden?</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.vcf_file.0">
        <source>VCF file</source>
        <target>VCF Datei</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.vcf_file.1">
        <source>Please select a VCF file (leave empty to generate one)</source>
        <target>Bitte wählen Sie eine VCF Datei (leer lassen wenn die Datei generiert werden soll)</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.singleSRC.0">
        <source>Image</source>
        <target>Bild</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.singleSRC.1">
        <source>Please select an image.</source>
        <target>Bitte wählen Sie ein Bild aus.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.jumpTo.0">
        <source>Redirect page</source>
        <target>Weiterleitungsseite</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.jumpTo.1">
        <source>Please choose the page to which visitors will be redirected when clicking on a contact person.</source>
        <target>Bitte wählen Sie die Seite aus, zu der Besucher beim Anklicken einer Ansprechperson weitergeleitet werden.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.pages.0">
        <source>Pages</source>
        <target>Seiten</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.pages.1">
        <source>Please select the pages on which this contact person should be displayed.</source>
        <target>Bitte wählen Sie auf welchen Seiten diese Ansprechpartner angezeigt werden soll.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.news.0">
        <source>News</source>
        <target>Nachrichten</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.news.1">
        <source>Please select the news items on which this contact person should be displayed.</source>
        <target>Bitte wählen Sie bei welchen Nachrichten diese Ansprechpartner angezeigt werden soll.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.events.0">
        <source>Events</source>
        <target>Events</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.events.1">
        <source>Please select the events on which this contact person should be displayed.</source>
        <target>Bitte wählen Sie auf bei welchen Events diese Ansprechpartner angezeigt werden soll.</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.published.0">
        <source>Publish</source>
        <target>Veröffentlichen</target>
    </trans-unit>
    <trans-unit id="tl_contact_person.published.1">
        <source>Display the contact persons on the website.</source>
        <target>Die Ansprechpartner auf der Webseite anzeigen.</target>
    </trans-unit>
</body>
</file>
